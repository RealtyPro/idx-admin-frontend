# Production environment variables
# These are committed to the repository and used during Vercel builds.
# To override any value, set the same key in the Vercel project dashboard
# (Settings → Environment Variables) — Vercel values take precedence.

# Backend API base URL - used by Next.js rewrites proxy
NEXT_API_BASE_URL=https://adminapi.realtipro.com/api

# Backend API base URL
#NEXT_PUBLIC_BACKEND_PRIMARY=https://demorealestate2.webnapps.net/api/
 #NEXT_PUBLIC_BACKEND_PRIMARY=http://145.223.121.84:3002/api/
 NEXT_PUBLIC_BACKEND_PRIMARY=https://adminapi.realtipro.com/api/

# Backend domain (base URL without path, used for storage/image URLs)
#NEXT_PUBLIC_BACKEND_DOMAIN=https://demorealestate2.webnapps.net
 #NEXT_PUBLIC_BACKEND_DOMAIN=http://145.223.121.84:3002/api/
 NEXT_PUBLIC_BACKEND_DOMAIN=https://adminapi.realtipro.com/api/
 #NEXT_PUBLIC_BACKEND_PRIMARY=http://104.225.217.254:8081/api/

# For image proxy rewrite (see next.config.js)
NEXT_ASSET_BASE_URL=https://adminapi.realtipro.com
