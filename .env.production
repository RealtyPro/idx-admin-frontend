# Production environment variables
# These are committed to the repository and used during Vercel builds.
# To override any value, set the same key in the Vercel project dashboard
# (Settings → Environment Variables) — Vercel values take precedence.

# Backend API base URL
NEXT_PUBLIC_BACKEND_PRIMARY=https://demorealestate2.webnapps.net/api/
# NEXT_PUBLIC_BACKEND_PRIMARY=https://adminapi.realtipro.com/api/


# Backend domain (base URL without path, used for storage/image URLs)
NEXT_PUBLIC_BACKEND_DOMAIN=https://demorealestate2.webnapps.net
# NEXT_PUBLIC_BACKEND_DOMAIN=https://adminapi.realtipro.com
